# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
wheels/
sdist/

# Virtual environments (any .venv* — local venvs are never committed)
.venv*/
venv/
env/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Docs build output
docs/_build/

# Editor / OS
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/

# Generated results live OUTSIDE the repo (hod_mod.paths.results_root; default
# ~/.local/share/hod_mod/results, override with $HOD_MOD_RESULTS). Curated results
# are archived on Zenodo and read back via hod_mod.data_io.fetch. Never track an
# in-repo results/ — guard against accidental re-accumulation:
/results/
hod_mod/results/

# Large external data not tracked in-repo
# APEC line/coco tables; soxs downloads these on demand
apec_v*.fits
# optional WHM-CAMB fork, installed via pip (see WHMSpectrum)
/WHM/

# Scratch / refactor files
_refactor_*.py
prompts.txt

# Coverage reports
.coverage.*
coverage.xml

# Type checking
.mypy_cache/
.ruff_cache/

# macOS
__MACOSX/
oarsub/logs/
hod_mod/data/xray_bands/
